source leaprc.protein.ff19SB
source leaprc.DNA.OL21
source leaprc.RNA.OL3
source leaprc.water.tip3p
source leaprc.gaff2

lig = loadmol2 tyl.antechamer.mol2
loadamberparams tyl.antechamer.frcmod
x = loadpdb rec_pH7.pdb4amber.pdb
complex = combine {x lig}

charge complex 

solvatebox complex TIP3PBOX 15 iso 

savepdb complex solvated.pdb
saveamberparm complex solvated.prmtop solvated.crd

quit
