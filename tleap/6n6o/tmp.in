source leaprc.protein.ff19SB
source leaprc.DNA.OL21
source leaprc.RNA.OL3
source leaprc.water.tip3p
source leaprc.gaff2

lig = loadmol2 LIGX.antechamer.mol2
loadamberparams LIGX.antechamer.frcmod
x = loadpdb rec_pH7.pdb4amber.pdb
complex = combine {x lig}
solvatebox complex TIP3PBOX 15 iso 

charge complex 

savepdb complex tmp.pdb
saveamberparm complex tmp.prmtop tmp.crd

quit
